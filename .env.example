# ============================================
# GlowUp AI - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================

# ─── APP CONFIG ────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GlowUp AI
NODE_ENV=development

# ─── SUPABASE ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── GOOGLE OAUTH (via Supabase Auth) ─────────
# Set up in Supabase Dashboard → Authentication → Providers → Google
# Get credentials from https://console.cloud.google.com/apis/credentials
# Callback URL to set in Google Console: https://your-project.supabase.co/auth/v1/callback
# No env vars needed here — configured in Supabase dashboard directly

# ─── AI / VISION MODEL ────────────────────────
# Gemini is FREE (get key at https://aistudio.google.com/apikey — no credit card)
# OpenAI is optional (paid, $5+ minimum)
GOOGLE_AI_API_KEY=your-google-gemini-api-key
GEMINI_MODEL=gemini-3.1-flash-lite

# Optional: OpenAI (paid — only set this if you have a real key)
# OPENAI_API_KEY=sk-your-openai-api-key

# ─── PAYMENT (RAZORPAY) ───────────────────────
RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your-key-id

# ─── PAYMENT (STRIPE - OPTIONAL) ──────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# ─── EMAIL (RESEND - RECOMMENDED FOR PRODUCTION) ──
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=GlowUp AI <noreply@glowupai.com>

# ─── EMAIL (GMAIL SMTP - FREE FALLBACK) ───────────
# Use this if you don't have Resend. Works with any Gmail account.
# Steps: Enable 2-Step Verification → Generate App Password at
# https://myaccount.google.com/apppasswords
# Daily limit: 500 emails/day (personal) or 2,000/day (Workspace)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-16-char-app-password

# ─── IMAGE STORAGE ─────────────────────────────
# Uses Supabase Storage by default
# Optional: Cloudinary for image transformations (FREE - 10GB storage, 20GB bandwidth/mo)
# Sign up at https://cloudinary.com (no credit card needed)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ─── RATE LIMITING ─────────────────────────────
# Option 1 (RECOMMENDED): Upstash Redis — <5ms latency, free tier: 10K req/day
# Sign up at https://upstash.com (no credit card needed)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token
# Option 2: Falls back to Supabase table (slower, ~100ms per check)
# Just run supabase/migrations/001_rate_limits.sql — no extra config needed
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MS=60000

# ─── SECURITY ──────────────────────────────────
# Secret used for signing tokens/sessions
AUTH_SECRET=your-random-32-character-secret-here
ENCRYPTION_KEY=your-256-bit-encryption-key

# ─── ANALYTICS (OPTIONAL) ─────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

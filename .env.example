# ============================================
# GlowUp AI - Environment Variables
# ============================================
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control
# ============================================

# ─── APP CONFIG ────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GlowUp AI
NODE_ENV=development

# ─── SUPABASE ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── AI / VISION MODEL ────────────────────────
# Choose one or both:
OPENAI_API_KEY=sk-your-openai-api-key
GOOGLE_AI_API_KEY=your-google-gemini-api-key

# ─── PAYMENT (RAZORPAY) ───────────────────────
RAZORPAY_KEY_ID=rzp_test_your-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_your-key-id

# ─── PAYMENT (STRIPE - OPTIONAL) ──────────────
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-stripe-publishable-key

# ─── EMAIL (RESEND) ───────────────────────────
RESEND_API_KEY=re_your-resend-api-key
EMAIL_FROM=noreply@glowupai.com

# ─── IMAGE STORAGE ─────────────────────────────
# Uses Supabase Storage by default
# Optional: Cloudinary for image transformations
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ─── RATE LIMITING ─────────────────────────────
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_MS=60000

# ─── SECURITY ──────────────────────────────────
# Secret used for signing tokens/sessions
AUTH_SECRET=your-random-32-character-secret-here
ENCRYPTION_KEY=your-256-bit-encryption-key

# ─── ANALYTICS (OPTIONAL) ─────────────────────
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_POSTHOG_KEY=phc_your-posthog-key
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
